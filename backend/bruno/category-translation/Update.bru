meta {
  name: Update
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/category-translations/{{categoryTranslationId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "categoryId": 2,
    "languageId": "vi",
    "name": "Điện tử",
    "description": "Thiết bị điện tử và tiện ích"
  }
}

vars:pre-request {
  categoryTranslationId: 1
}
