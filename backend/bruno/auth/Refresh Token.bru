meta {
  name: Refresh Token
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/auth/refresh-token
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "token": "{{refreshToken}}"
  }
}

script:post-response {
  const body = res.body;
    if (body.accessToken) {
      bru.setEnvVar("accessToken", body.accessToken);
      bru.setEnvVar("refreshToken", body.refreshToken);
    }
}