meta {
  name: Create User
  type: http
  seq: 16
}

post {
  url: {{baseUrl}}/users
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "email": "newuser@example.com",
    "password": "123456",
    "name": "New User",
    "phoneNumber": "0901234567",
    "roleId": 2,
    "status": "ACTIVE",
    "avatar": null
  }
}
